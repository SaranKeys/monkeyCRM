datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  EMPLOYEE
  CLIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERN
  CONTRACTOR
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  PAUSED
  CHURNED
}

enum EngagementType {
  PROJECT
  RETAINER
  RETAINER_BUILD
}

// enum ProjectType {
//   WEBSITE
//   WEB_APP
//   CRM
//   E_COMMERCE
//   MOBILE_APP
//   DIGITAL_MARKETING
//   MAINTENANCE
//   AUTOMATION
//   AI_WORKFLOW
//   AI_AGENT
// }

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum MilestoneType {
  INTERNAL_MEETING
  CLIENT_MEETING
  MILESTONE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum MilestoneStatus {
  UPCOMING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ApprovalStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
  REWORK_REQUESTED
}

enum PhaseStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
}

enum TaskStatus {
  TO_DO
  IN_PROGRESS
  BLOCKED
  DONE
}


type Attachment {
  name String
  url  String
  type String // 'video', 'document', 'image'
}


// Embedded Documents
type AdditionalContact {
  name  String
  role  String
  email String
  phone String
  tag   String // 'billing', 'technical', 'escalation'
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employeeProfile EmployeeProfile?
  clientProfile   ClientProfile?

  createdTickets Ticket[]        @relation("TicketCreator")
  ticketComments TicketComment[] @relation("CommentAuthor")

  projectUpdates ProjectUpdate[] @relation("UpdateAuthor")
  updateReplies  UpdateReply[]   @relation("UpdateReplyAuthor")

  uploadedFiles ProjectFile[] @relation("FileUploader")

  @@map("users")
}

model EmployeeProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal & Identity
  legalName       String
  preferredName   String?
  dob             DateTime
  gender          Gender
  profilePhotoUrl String?
  personalMobile  String
  bloodGroup      String?

  // Emergency Contact
  emergencyName     String
  emergencyRelation String
  emergencyPhone    String

  // KYC & Identity Documents
  aadhaarNumber   String @unique
  aadhaarFrontUrl String // csu
  aadhaarBackUrl  String // csu
  panNumber       String @unique
  panPhotoUrl     String // csu

  // Address
  currentAddress   String
  addressProofUrl  String // csu
  permanentAddress String

  // Bank & Payroll
  accountName     String
  bankName        String
  accountNumber   String
  ifscCode        String
  branchName      String
  bankDocumentUrl String // Passbook or Cancelled Cheque URL

  // Employment Details
  designation      String
  department       String
  reportingManager String? // Can be linked to another User ID later
  employmentType   EmploymentType
  workMode         WorkMode
  baseLocation     String
  dateOfJoining    DateTime
  probationDays    Int
  totalExperience  Float
  relevantExp      Float

  // Relations to Projects
  ledProjects Project[] @relation("ProjectLead")

  projectIds String[]  @db.ObjectId
  projects   Project[] @relation("ProjectMembers", fields: [projectIds], references: [id])

  assignedTickets Ticket[] @relation("TicketAssignee")

  ownedMilestones ProjectMilestone[] @relation("MilestoneOwner")

  updatesToApprove ProjectUpdate[] @relation("UpdateApprover")

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  // projectMilestones ProjectMilestone[]

  ledPhases     ProjectPhase[] @relation("PhaseLead")
  assignedTasks PhaseTask[]    @relation("TaskAssignee")

  sentMessages ChatMessage[] @relation("ChatSender")
  

  @@map("employee_profiles")
}

model ClientProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Company Basics
  companyName String // Required
  brandName   String?
  logoUrl     String? // csu
  website     String?
  industry    String?
  companySize String?
  foundedYear Int?
  description String?
  linkedin    String?

  // Primary Contact
  contactName        String // Required
  contactEmail       String // Required
  contactPhone       String // Required
  contactDesignation String?
  contactMethod      String?
  timezone           String?

  // Additional Contacts (Embedded Array)
  additionalContacts AdditionalContact[]

  // Addresses
  registeredAddress String?
  operatingAddress  String?
  country           String?

  // Billing & Legal
  billingCurrency String?
  billingContact  String?
  billingEmail    String?
  taxId           String? // Dynamic based on region
  paymentTerms    String?
  paymentMethod   String?
  poRequired      Boolean? @default(false)

  // Relationship / Commercial
  clientSince    DateTime?
  source         String?
  accountOwner   String?
  engagementType EngagementType?
  status         ClientStatus?   @default(PROSPECT)

  // Document URLs (Drive URLs)
  msaUrl         String?
  ndaUrl         String?
  taxCertUrl     String?
  brandAssetsUrl String?

  // Relation to Projects
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_profiles")
}

model CompanyRole {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String  @unique
  description String?

  permissions Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_roles")
}

model ServiceTemplate {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String @unique
  icon String

  page2Fields Json

  isActive Boolean @default(true)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_templates")
}

//  project flow 
model Project {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  // basic Details
  name        String
  description String?

  serviceId String          @db.ObjectId
  service   ServiceTemplate @relation(fields: [serviceId], references: [id])

  priority       ProjectPriority
  engagementType EngagementType
  status         ProjectStatus   @default(ACTIVE)

  // relation to Client
  clientId String        @db.ObjectId
  client   ClientProfile @relation(fields: [clientId], references: [id])

  clientRequirements Json?

  estimatedHours     Int?
  techStack          String[]
  customInstructions String?

  // "+1 / +2" Resource Counters
  requiredResources Json?

  // Relation: Project Lead 
  leadId String?          @db.ObjectId
  lead   EmployeeProfile? @relation("ProjectLead", fields: [leadId], references: [id])

  // Relation: Project Members
  memberIds String[]          @db.ObjectId
  members   EmployeeProfile[] @relation("ProjectMembers", fields: [memberIds], references: [id])

  // Project Runway
  milestones ProjectMilestone[]

  tickets Ticket[]

  updates ProjectUpdate[]

  phases ProjectPhase[]

  chatMessages ChatMessage[]

  projectFiles ProjectFile[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
}

model ProjectMilestone {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  type        MilestoneType
  dueDate     DateTime

  status MilestoneStatus @default(UPCOMING)

  ownerId String?          @db.ObjectId
  
  owner   EmployeeProfile? @relation("MilestoneOwner", fields: [ownerId], references: [id])

  agenda      String?
  decisions   String?
  actionItems String?

  isCompleted Boolean @default(false)

  projectId String  @db.ObjectId
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_milestones")
}

model Ticket {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  ticketNumber String @unique

  subject  String
  details  String
  priority ProjectPriority
  status   TicketStatus    @default(OPEN)

  projectId String  @db.ObjectId
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  creatorId String @db.ObjectId
  creator   User   @relation("TicketCreator", fields: [creatorId], references: [id])

  assigneeId String?          @db.ObjectId
  assignee   EmployeeProfile? @relation("TicketAssignee", fields: [assigneeId], references: [id])

  comments TicketComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tickets")
}

model TicketComment {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  text String

  ticketId String @db.ObjectId
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String @db.ObjectId
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ticket_comments")
}


model ProjectUpdate {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  content String

  attachments Attachment[]

  clientView     Boolean        @default(true)
  approvalStatus ApprovalStatus @default(NONE)

  projectId String  @db.ObjectId
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  authorId String @db.ObjectId
  author   User   @relation("UpdateAuthor", fields: [authorId], references: [id])

  replies UpdateReply[]

  assignedApproverId String?          @db.ObjectId
  assignedApprover   EmployeeProfile? @relation("UpdateApprover", fields: [assignedApproverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_updates")
}


model UpdateReply {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  text String

  updateId String        @db.ObjectId
  update   ProjectUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)

  authorId String @db.ObjectId
  author   User   @relation("UpdateReplyAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("update_replies")
}


model ProjectPhase {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  description    String?
  startDate      DateTime
  dueDate        DateTime
  priority       ProjectPriority @default(MEDIUM)
  status         PhaseStatus     @default(UPCOMING)
  
  estimatedHours Int             @default(0)
  loggedHours    Int             @default(0)

  deliverables   Attachment[]

  projectId      String          @db.ObjectId
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  leadId         String?         @db.ObjectId
  lead           EmployeeProfile? @relation("PhaseLead", fields: [leadId], references: [id])

  subPhases      PhaseSubPhase[]
  tasks          PhaseTask[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("project_phases")
}

model PhaseSubPhase {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  name      String

  phaseId   String       @db.ObjectId
  phase     ProjectPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  tasks     PhaseTask[]

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("phase_sub_phases")
}

model PhaseTask {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  startDate   DateTime?
  dueDate     DateTime?

  priority    ProjectPriority @default(MEDIUM)
  status      TaskStatus      @default(TO_DO)

  phaseId     String          @db.ObjectId
  phase       ProjectPhase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  subPhaseId  String?         @db.ObjectId
  subPhase    PhaseSubPhase?  @relation(fields: [subPhaseId], references: [id], onDelete: SetNull)

  assigneeId  String?         @db.ObjectId
  assignee    EmployeeProfile? @relation("TaskAssignee", fields: [assigneeId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("phase_tasks")
}

model ChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  text      String

  projectId String   @db.ObjectId
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  senderId  String          @db.ObjectId
  sender    EmployeeProfile @relation("ChatSender", fields: [senderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_messages")
}

model ProjectFile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String    
  url         String 
  driveFileId String    
  type        String    
  
  projectId   String   @db.ObjectId
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  uploaderId  String   @db.ObjectId
  uploader    User     @relation("FileUploader", fields: [uploaderId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("project_files")
}